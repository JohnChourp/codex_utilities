{
  "schema_version": 1,
  "skill_name": "skill-installer",
  "execution_mode": "python_launcher",
  "supported_os": [
    "macos",
    "linux",
    "windows"
  ],
  "unsupported_behavior": "fail_fast",
  "preflight": {
    "cache_ttl_seconds": 600,
    "checks": [
      {
        "type": "tool",
        "name": "python",
        "install_hint": {
          "macos": "Install Python 3 and ensure python3 is in PATH.",
          "linux": "Install python3 and ensure it is in PATH.",
          "windows": "Install Python 3 or the py launcher and ensure it is in PATH."
        }
      },
      {
        "type": "tool",
        "name": "git",
        "install_hint": {
          "default": "Install Git and ensure it is in PATH."
        }
      }
    ]
  },
  "entrypoint": {
    "kind": "python",
    "path": "scripts/run.py"
  },
  "tooling": {
    "python": {
      "macos": [
        "python3"
      ],
      "linux": [
        "python3"
      ],
      "windows": [
        "py",
        "-3"
      ]
    },
    "git": {
      "macos": [
        "git"
      ],
      "linux": [
        "git"
      ],
      "windows": [
        "git"
      ]
    }
  },
  "default_command": "install-skill-from-github",
  "commands": [
    {
      "name": "install-skill-from-github",
      "description": "Run install-skill-from-github.py",
      "kind": "python",
      "path": "scripts/install-skill-from-github.py",
      "args": []
    },
    {
      "name": "list-skills",
      "description": "Run list-skills.py",
      "kind": "python",
      "path": "scripts/list-skills.py",
      "args": []
    }
  ]
}
