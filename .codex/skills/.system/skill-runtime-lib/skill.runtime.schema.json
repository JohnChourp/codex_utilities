{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codex.local/skill.runtime.schema.v2.json",
  "title": "Codex Skill Runtime Schema",
  "type": "object",
  "required": [
    "schema_version",
    "skill_name",
    "execution_mode",
    "supported_os",
    "unsupported_behavior",
    "preflight",
    "tooling"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "enum": [2]
    },
    "skill_name": {
      "type": "string",
      "minLength": 1
    },
    "execution_mode": {
      "type": "string",
      "enum": ["guidance", "python", "python_launcher", "shell"]
    },
    "supported_os": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": ["macos", "linux", "windows"]
      }
    },
    "unsupported_behavior": {
      "type": "string"
    },
    "preflight": {
      "type": "object",
      "required": ["checks"],
      "properties": {
        "cache_ttl_seconds": {
          "type": "integer"
        },
        "checks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["type", "name"],
            "properties": {
              "type": {
                "type": "string",
                "const": "tool"
              },
              "name": {
                "type": "string",
                "minLength": 1
              },
              "install_hint": {
                "type": "object"
              }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "entrypoint": {
      "type": ["object", "null"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["python", "shell"]
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "args": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": ["kind", "path"],
      "additionalProperties": true
    },
    "tooling": {
      "type": "object"
    },
    "default_command": {
      "type": "string"
    },
    "commands": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/command"
      }
    },
    "recording": {
      "type": "object",
      "properties": {
        "enabled_by_default": {
          "type": "boolean"
        },
        "output_dir_template": {
          "type": "string",
          "minLength": 1
        },
        "artifacts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    }
  },
  "$defs": {
    "command": {
      "type": "object",
      "required": ["name", "kind", "path"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "kind": {
          "type": "string",
          "enum": ["python", "shell"]
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "args": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "os_entrypoints": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/command_override"
          }
        },
        "wrappers": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/command_override"
          }
        }
      },
      "additionalProperties": true
    },
    "command_override": {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["python", "shell"]
        },
        "path": {
          "type": "string"
        },
        "args": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
