{
  "schema_version": 2,
  "skill_name": "optc-box-audit-loop",
  "execution_mode": "python_launcher",
  "supported_os": [
    "macos",
    "linux"
  ],
  "unsupported_behavior": "fail_fast",
  "preflight": {
    "cache_ttl_seconds": 600,
    "checks": [
      {
        "type": "tool",
        "name": "bash",
        "install_hint": {
          "macos": "Install bash and ensure it is in PATH.",
          "linux": "Install bash and ensure it is in PATH."
        }
      }
    ]
  },
  "entrypoint": {
    "kind": "python",
    "path": "scripts/run.py"
  },
  "tooling": {
    "bash": {
      "macos": [
        "bash"
      ],
      "linux": [
        "bash"
      ]
    },
    "python": {
      "macos": [
        "python3"
      ],
      "linux": [
        "python3"
      ],
      "windows": [
        "py",
        "-3"
      ]
    }
  },
  "default_command": "audit-case",
  "commands": [
    {
      "name": "audit-case",
      "description": "Run the OPTC audit loop",
      "kind": "shell",
      "path": "scripts/run.sh",
      "args": []
    }
  ],
  "recording": {
    "enabled_by_default": false,
    "output_dir_template": "$CODEX_HOME/tmp/skill-runs/{skill}/{timestamp}",
    "artifacts": [
      "run.json",
      "command.txt",
      "stdout.log",
      "stderr.log"
    ]
  }
}
