{
  "printWidth": 150,
  "bracketSameLine": true,
  "useEditorConfig": false,
  "semi": true,
  "trailingComma": "all",
  "arrowParens": "avoid",
  "tabWidth": 2,
  "endOfLine": "lf",
  "quoteProps": "as-needed",
  "singleQuote": false,
  "jsxSingleQuote": false,
  "overrides": [
    {
      "files": "*.html",
      "options": {
        "parser": "angular"
      }
    }
  ]
}
